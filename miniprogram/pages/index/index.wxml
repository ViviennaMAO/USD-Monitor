<view class="container">
  <!-- Loading -->
  <view wx:if="{{loading}}" style="text-align:center;padding:100rpx 0;">
    <text class="text-muted">Loading...</text>
  </view>

  <block wx:else>
    <!-- Header: DXY Price + Signal + VSTAR -->
    <view class="card" style="padding:20rpx 24rpx;">
      <view class="flex justify-between items-center">
        <view>
          <text class="text-gold font-bold" style="font-size:20rpx;">USD Valuation Model</text>
          <text class="text-muted text-xs" style="margin-left:12rpx;">v1.0</text>
        </view>
        <view class="flex items-center" style="gap:12rpx;">
          <view class="badge {{signalClass}}">{{signalText}}</view>
          <view class="vstar-btn" bindtap="openVstar">VSTAR 交易</view>
        </view>
      </view>
      <view class="flex justify-between items-center" style="margin-top:12rpx;">
        <view class="flex items-center gap-sm">
          <text class="text-muted text-sm">DXY</text>
          <text class="text-white font-bold text-xl font-mono">{{dxyPrice}}</text>
          <text class="{{dxyChangeClass}} text-sm font-mono">{{dxyChange}}</text>
        </view>
        <view class="flex-col" style="align-items:flex-end;">
          <text class="text-muted text-xs">{{dataDate}}</text>
          <text class="text-muted text-xs">{{dataTime}}</text>
        </view>
      </view>
    </view>

    <!-- Score Gauge -->
    <view class="card" style="display:flex;flex-direction:column;align-items:center;">
      <canvas type="2d" id="gaugeCanvas" style="width:280rpx;height:220rpx;"></canvas>
      <view class="flex justify-between" style="width:100%;margin-top:16rpx;">
        <text class="text-xs text-muted">&#60;35 看空</text>
        <text class="text-xs text-muted">35-65 中性</text>
        <text class="text-xs text-muted">&#62;65 看多</text>
      </view>
    </view>

    <!-- Component Scores Grid -->
    <view class="card">
      <view class="card-header">
        <text class="card-title">评分分项</text>
        <text class="text-gold text-xs">gamma = r_f + pi - cy + sigma</text>
      </view>

      <!-- 2x2 Grid -->
      <view style="display:grid;grid-template-columns:1fr 1fr;gap:16rpx;">
        <!-- r_f -->
        <view style="background:rgba(34,197,94,0.06);border:1rpx solid rgba(34,197,94,0.15);border-radius:12rpx;padding:16rpx;">
          <view class="flex justify-between items-center">
            <text class="text-sm text-muted">r_f</text>
            <text class="text-green font-bold font-mono">{{rfScore}}</text>
          </view>
          <text class="text-xs text-muted" style="margin-top:4rpx;">利率差异支撑</text>
          <view class="progress-bar" style="margin-top:8rpx;">
            <view class="progress-fill" style="width:{{rfScore}}%;background:#22C55E;"></view>
          </view>
        </view>

        <!-- pi_risk -->
        <view style="background:rgba(245,158,11,0.06);border:1rpx solid rgba(245,158,11,0.15);border-radius:12rpx;padding:16rpx;">
          <view class="flex justify-between items-center">
            <text class="text-sm text-muted">pi_risk</text>
            <text class="text-amber font-bold font-mono">{{piScore}}</text>
          </view>
          <text class="text-xs text-muted" style="margin-top:4rpx;">风险溢价</text>
          <view class="progress-bar" style="margin-top:8rpx;">
            <view class="progress-fill" style="width:{{piScore}}%;background:#F59E0B;"></view>
          </view>
        </view>

        <!-- cy -->
        <view style="background:rgba(239,68,68,0.06);border:1rpx solid rgba(239,68,68,0.15);border-radius:12rpx;padding:16rpx;">
          <view class="flex justify-between items-center">
            <text class="text-sm text-muted">cy</text>
            <text class="text-red font-bold font-mono">{{cyScore}}</text>
          </view>
          <text class="text-xs text-muted" style="margin-top:4rpx;">便利收益 (拖累)</text>
          <view class="progress-bar" style="margin-top:8rpx;">
            <view class="progress-fill" style="width:{{cyScore}}%;background:#EF4444;"></view>
          </view>
        </view>

        <!-- sigma_alert -->
        <view style="background:rgba(249,115,22,0.06);border:1rpx solid rgba(249,115,22,0.15);border-radius:12rpx;padding:16rpx;">
          <view class="flex justify-between items-center">
            <text class="text-sm text-muted">sigma</text>
            <text class="text-orange font-bold font-mono">{{sigmaScore}}</text>
          </view>
          <view class="flex justify-between items-center" style="margin-top:4rpx;">
            <text class="text-xs text-muted">波动率预警</text>
            <view class="badge {{alertClass}}" style="font-size:18rpx;padding:2rpx 8rpx;">{{alertText}}</view>
          </view>
          <view class="progress-bar" style="margin-top:8rpx;">
            <view class="progress-fill" style="width:{{sigmaScore}}%;background:#F97316;"></view>
          </view>
        </view>
      </view>
    </view>

    <!-- Quick Stats -->
    <view class="card">
      <view class="card-header">
        <text class="card-title">关键数据</text>
      </view>
      <view class="data-row">
        <text class="data-label">10Y TIPS 实际利率</text>
        <text class="data-value">{{realRate}}</text>
      </view>
      <view class="data-row">
        <text class="data-label">SOFR</text>
        <text class="data-value">{{sofr}}</text>
      </view>
      <view class="data-row">
        <text class="data-label">波动率推升因子</text>
        <text class="data-value text-red">{{pushCount}} 个</text>
      </view>
      <view class="data-row">
        <text class="data-label">波动率压制因子</text>
        <text class="data-value text-green">{{suppressCount}} 个</text>
      </view>
      <view class="data-row">
        <text class="data-label">净方向</text>
        <text class="data-value {{netDirection === '扩张' ? 'text-red' : 'text-green'}}">{{netDirection}}</text>
      </view>
    </view>
  </block>
</view>
