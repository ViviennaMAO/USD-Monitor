.stat-cell {
  background: rgba(15, 23, 42, 0.6);
  border: 1rpx solid rgba(51, 65, 85, 0.5);
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
}
.stat-label {
  font-size: 22rpx;
  color: #64748b;
  margin-bottom: 8rpx;
}
.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #e2e8f0;
}
.stat-sub {
  margin-top: 4rpx;
}
