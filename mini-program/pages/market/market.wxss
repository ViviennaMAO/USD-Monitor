.page { min-height: 100vh; }
.tab-content { padding-top: 20rpx; padding-bottom: 40rpx; }

/* Single shared chart canvas — overflow:hidden prevents native canvas
   layer from bleeding over other tabs when switching away from Tab 0 */
.corr-chart { width: 100%; height: 100%; display: block; }
.tab-content .card { overflow: hidden; position: relative; }

/* Period toggle */
.period-toggle { display: flex; gap: 12rpx; }
.period-btn {
  padding: 8rpx 24rpx; border-radius: 20rpx; font-size: 24rpx;
  color: #64748b; background: rgba(15,23,42,0.6); border: 1rpx solid rgba(51,65,85,0.5);
}
.period-btn.active { color: #38bdf8; border-color: #38bdf8; background: rgba(56,189,248,0.1); }

/* Rates / Liquidity verification panels */
.verify-card {
  background: rgba(15,23,42,0.6); border: 1rpx solid rgba(51,65,85,0.5);
  border-radius: 20rpx; padding: 24rpx; margin-bottom: 20rpx;
}
.verify-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16rpx; }
.verify-title { font-size: 28rpx; font-weight: 600; color: #e2e8f0; }

/* Status badges */
.status-confirmed { background: rgba(52,211,153,0.15); color: #34d399; }
.status-pending { background: rgba(251,191,36,0.15); color: #fbbf24; }
.status-unconfirmed { background: rgba(248,113,113,0.15); color: #f87171; }

/* Indicator rows */
.ind-row {
  display: flex; flex-direction: row; align-items: center;
  padding: 14rpx 0; border-bottom: 1rpx solid rgba(51,65,85,0.15);
}
.ind-row:last-child { border-bottom: none; }
.ind-dot { width: 16rpx; height: 16rpx; border-radius: 50%; margin-right: 16rpx; flex-shrink: 0; }
.ind-dot-green { background: #34d399; }
.ind-dot-yellow { background: #fbbf24; }
.ind-dot-red { background: #f87171; }
.ind-name { flex: 1; font-size: 24rpx; color: #cbd5e1; }
.ind-value { font-size: 24rpx; font-weight: 600; color: #e2e8f0; min-width: 100rpx; text-align: right; }
.ind-status { font-size: 20rpx; margin-left: 12rpx; min-width: 80rpx; text-align: center; }

/* Trigger conditions */
.trigger-box {
  background: rgba(15,23,42,0.8); border: 1rpx solid rgba(51,65,85,0.3);
  border-radius: 16rpx; padding: 20rpx; margin-top: 16rpx;
}
.trigger-item { display: flex; align-items: flex-start; padding: 8rpx 0; }
.trigger-bullet { color: #fbbf24; margin-right: 12rpx; font-size: 24rpx; flex-shrink: 0; }
.trigger-text { font-size: 22rpx; color: #94a3b8; line-height: 1.6; }

/* Judgment summary */
.judgment-bar {
  display: flex; align-items: center; gap: 16rpx;
  padding: 16rpx 24rpx; border-radius: 16rpx; margin-bottom: 20rpx;
}
.judgment-bull { background: rgba(52,211,153,0.1); border: 1rpx solid rgba(52,211,153,0.3); }
.judgment-bear { background: rgba(248,113,113,0.1); border: 1rpx solid rgba(248,113,113,0.3); }
.judgment-neutral { background: rgba(251,191,36,0.1); border: 1rpx solid rgba(251,191,36,0.3); }
.judgment-icon { font-size: 36rpx; }
.judgment-text { flex: 1; font-size: 26rpx; font-weight: 600; }

/* Score row */
.score-row { display: flex; gap: 16rpx; margin-bottom: 20rpx; }
.score-item {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  background: rgba(15,23,42,0.6); border: 1rpx solid rgba(51,65,85,0.5);
  border-radius: 16rpx; padding: 16rpx;
}
.score-label { font-size: 20rpx; color: #64748b; margin-bottom: 6rpx; }
.score-value { font-size: 32rpx; font-weight: 700; color: #e2e8f0; }
