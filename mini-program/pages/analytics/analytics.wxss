.page { min-height: 100vh; }
.tab-content { padding-top: 20rpx; padding-bottom: 40rpx; }

/* Single shared chart canvas */
.main-chart { width: 100%; height: 100%; }

/* Factor pills */
.factor-scroll { white-space: nowrap; padding: 16rpx 0; }
.factor-pills { display: inline-flex; gap: 12rpx; }
.factor-pill {
  display: inline-flex; align-items: center; justify-content: center;
  padding: 8rpx 24rpx; border-radius: 20rpx; font-size: 24rpx;
  color: #64748b; background: rgba(15,23,42,0.6); border: 1rpx solid rgba(51,65,85,0.5);
}
.factor-pill.active { color: #38bdf8; border-color: #38bdf8; background: rgba(56,189,248,0.1); }

/* 3-col grid for NAV stats */
.grid-3col { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16rpx; }
.g-card-sm {
  display: flex; flex-direction: column;
  background: rgba(15,23,42,0.6); border: 1rpx solid rgba(51,65,85,0.5);
  border-radius: 16rpx; padding: 20rpx 16rpx;
}
.g-label { font-size: 22rpx; color: #64748b; margin-bottom: 8rpx; }
.g-value-sm { font-size: 32rpx; font-weight: 700; color: #e2e8f0; line-height: 1.2; }

/* ═══ Model Health Tab Styles ═══ */

.health-banner { margin-bottom: 20rpx; }

/* Health indicators grid */
.health-grid {
  display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 24rpx;
}
.health-cell {
  width: calc(50% - 8rpx); display: flex; flex-direction: row; align-items: center; gap: 12rpx;
  background: rgba(15,23,42,0.6); border: 1rpx solid rgba(51,65,85,0.5);
  border-radius: 16rpx; padding: 16rpx 20rpx;
}
.health-dot {
  width: 16rpx; height: 16rpx; border-radius: 50%; flex-shrink: 0;
}
.dot-green { background: #34d399; }
.dot-yellow { background: #fbbf24; }
.dot-red { background: #f87171; }

/* CPCV grid */
.cpcv-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx;
}
.cpcv-item {
  display: flex; flex-direction: column; align-items: center;
  padding: 16rpx 0;
}

/* Circuit breaker rows */
.cb-row {
  display: flex; justify-content: space-between; align-items: center;
  padding: 14rpx 0; border-bottom: 1rpx solid rgba(51,65,85,0.2);
}
