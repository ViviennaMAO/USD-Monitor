/* ===== USD Monitor Global Styles ===== */
/* Dark theme matching Next.js dashboard */

page {
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  line-height: 1.5;
  color: #e2e8f0;
  background-color: #0a0e1a;
  box-sizing: border-box;
}

view, text, image, input, scroll-view {
  box-sizing: border-box;
}

/* ===== Color tokens ===== */
.text-bull { color: #34d399; }
.text-bear { color: #f87171; }
.text-neutral { color: #fbbf24; }
.text-accent { color: #38bdf8; }
.text-muted { color: #64748b; }
.text-body { color: #cbd5e1; }
.text-white { color: #ffffff; }

.bg-card { background: rgba(15, 23, 42, 0.6); }
.bg-surface { background: #0f1729; }
.bg-page { background: #0a0e1a; }

/* ===== Layout ===== */
.flex { display: flex; }
.flex-row { display: flex; flex-direction: row; }
.flex-col { display: flex; flex-direction: column; }
.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; }
.items-center { align-items: center; }
.justify-center { justify-content: center; }
.justify-between { justify-content: space-between; }
.justify-around { justify-content: space-around; }

/* ===== Spacing ===== */
.p-20 { padding: 20rpx; }
.p-24 { padding: 24rpx; }
.p-30 { padding: 30rpx; }
.px-24 { padding-left: 24rpx; padding-right: 24rpx; }
.px-30 { padding-left: 30rpx; padding-right: 30rpx; }
.py-16 { padding-top: 16rpx; padding-bottom: 16rpx; }
.py-20 { padding-top: 20rpx; padding-bottom: 20rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-24 { margin-top: 24rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-20 { margin-bottom: 20rpx; }
.gap-16 { gap: 16rpx; }
.gap-20 { gap: 20rpx; }

/* ===== Typography ===== */
.text-xs { font-size: 22rpx; }
.text-sm { font-size: 24rpx; }
.text-base { font-size: 28rpx; }
.text-lg { font-size: 32rpx; }
.text-xl { font-size: 36rpx; }
.text-2xl { font-size: 44rpx; }
.text-3xl { font-size: 56rpx; }
.font-medium { font-weight: 500; }
.font-semibold { font-weight: 600; }
.font-bold { font-weight: 700; }
.text-center { text-align: center; }
.text-right { text-align: right; }

/* ===== Card ===== */
.card {
  background: rgba(15, 23, 42, 0.6);
  border: 1rpx solid rgba(51, 65, 85, 0.5);
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 26rpx;
  color: #94a3b8;
  font-weight: 500;
  margin-bottom: 12rpx;
}

/* ===== Badge ===== */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
}
.badge-bull { background: rgba(52, 211, 153, 0.15); color: #34d399; }
.badge-bear { background: rgba(248, 113, 113, 0.15); color: #f87171; }
.badge-neutral { background: rgba(251, 191, 36, 0.15); color: #fbbf24; }
.badge-info { background: rgba(56, 189, 248, 0.15); color: #38bdf8; }

/* ===== Divider ===== */
.divider {
  height: 1rpx;
  background: rgba(51, 65, 85, 0.4);
  margin: 20rpx 0;
}

/* ===== Tab bar ===== */
.tab-bar {
  display: flex;
  flex-direction: row;
  background: #0f1729;
  border-bottom: 1rpx solid rgba(51, 65, 85, 0.5);
  padding: 0 12rpx;
}
.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 26rpx;
  color: #64748b;
  position: relative;
}
.tab-item.active {
  color: #38bdf8;
  font-weight: 600;
}
.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 25%;
  width: 50%;
  height: 4rpx;
  background: #38bdf8;
  border-radius: 4rpx;
}

/* ===== Stat grid ===== */
.stat-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}
.stat-cell {
  width: calc(50% - 8rpx);
  background: rgba(15, 23, 42, 0.6);
  border: 1rpx solid rgba(51, 65, 85, 0.5);
  border-radius: 16rpx;
  padding: 20rpx;
}
.stat-cell-3 {
  width: calc(33.33% - 12rpx);
}
.stat-label {
  font-size: 22rpx;
  color: #64748b;
  margin-bottom: 8rpx;
}
.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #e2e8f0;
}

/* ===== Loading ===== */
.loading-wrap {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}
.loading-text {
  font-size: 26rpx;
  color: #64748b;
}

/* ===== Section header ===== */
.section-header {
  display: flex;
  align-items: center;
  margin: 30rpx 0 20rpx;
}
.section-line {
  flex: 1;
  height: 1rpx;
  background: rgba(51, 65, 85, 0.4);
}
.section-title {
  font-size: 24rpx;
  color: #64748b;
  padding: 0 20rpx;
  white-space: nowrap;
}
