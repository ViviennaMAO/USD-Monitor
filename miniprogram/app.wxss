page {
  background-color: #050810;
  color: #E5E7EB;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 28rpx;
}

.container {
  padding: 20rpx;
  min-height: 100vh;
}

/* Cards */
.card {
  background: linear-gradient(135deg, rgba(15, 23, 42, 0.95), rgba(10, 14, 26, 0.95));
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 28rpx;
  color: #9CA3AF;
  font-weight: 500;
}

.card-subtitle {
  font-size: 22rpx;
  color: #6B7280;
}

/* Signal Badges */
.badge {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.badge-bullish {
  background: rgba(34, 197, 94, 0.15);
  color: #22C55E;
  border: 1rpx solid rgba(34, 197, 94, 0.3);
}

.badge-neutral {
  background: rgba(245, 158, 11, 0.15);
  color: #F59E0B;
  border: 1rpx solid rgba(245, 158, 11, 0.3);
}

.badge-bearish {
  background: rgba(239, 68, 68, 0.15);
  color: #EF4444;
  border: 1rpx solid rgba(239, 68, 68, 0.3);
}

/* Alert Level Badges */
.badge-alert {
  background: rgba(239, 68, 68, 0.15);
  color: #EF4444;
  border: 1rpx solid rgba(239, 68, 68, 0.3);
}

.badge-warning {
  background: rgba(249, 115, 22, 0.15);
  color: #F97316;
  border: 1rpx solid rgba(249, 115, 22, 0.3);
}

.badge-watch {
  background: rgba(245, 158, 11, 0.15);
  color: #F59E0B;
  border: 1rpx solid rgba(245, 158, 11, 0.3);
}

.badge-calm {
  background: rgba(34, 197, 94, 0.15);
  color: #22C55E;
  border: 1rpx solid rgba(34, 197, 94, 0.3);
}

/* Direction indicators */
.dir-push {
  color: #EF4444;
}

.dir-latent {
  color: #F59E0B;
}

.dir-suppress {
  color: #22C55E;
}

.dir-neutral {
  color: #9CA3AF;
}

/* Score colors */
.score-high {
  color: #22C55E;
}

.score-mid {
  color: #F59E0B;
}

.score-low {
  color: #EF4444;
}

/* Progress bars */
.progress-bar {
  height: 8rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.3s;
}

/* Tab styles */
.tab-bar {
  display: flex;
  background: rgba(15, 23, 42, 0.8);
  border-radius: 16rpx;
  padding: 6rpx;
  margin-bottom: 20rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 14rpx 20rpx;
  font-size: 24rpx;
  color: #9CA3AF;
  border-radius: 12rpx;
  min-width: 120rpx;
}

.tab-item.active {
  background: rgba(251, 191, 36, 0.15);
  color: #FBBF24;
}

/* Data rows */
.data-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
}

.data-row:last-child {
  border-bottom: none;
}

.data-label {
  color: #9CA3AF;
  font-size: 24rpx;
}

.data-value {
  color: #E5E7EB;
  font-size: 24rpx;
  font-family: 'JetBrains Mono', monospace;
}

/* Utility */
.text-green { color: #22C55E; }
.text-red { color: #EF4444; }
.text-amber { color: #F59E0B; }
.text-orange { color: #F97316; }
.text-cyan { color: #06B6D4; }
.text-gold { color: #FBBF24; }
.text-muted { color: #6B7280; }
.text-white { color: #F9FAFB; }

.text-lg { font-size: 36rpx; }
.text-xl { font-size: 44rpx; }
.text-2xl { font-size: 56rpx; }
.text-sm { font-size: 22rpx; }
.text-xs { font-size: 20rpx; }
.font-bold { font-weight: 700; }
.font-mono { font-family: 'JetBrains Mono', monospace; }

.flex { display: flex; }
.flex-col { flex-direction: column; }
.items-center { align-items: center; }
.justify-between { justify-content: space-between; }
.gap-sm { gap: 12rpx; }
.gap-md { gap: 20rpx; }
.mt-sm { margin-top: 12rpx; }
.mt-md { margin-top: 20rpx; }
.mb-sm { margin-bottom: 12rpx; }

/* Note box */
.note-box {
  background: rgba(251, 191, 36, 0.06);
  border-left: 4rpx solid #FBBF24;
  padding: 16rpx 20rpx;
  border-radius: 0 12rpx 12rpx 0;
  margin-top: 16rpx;
  font-size: 22rpx;
  color: #D1D5DB;
  line-height: 1.5;
}
