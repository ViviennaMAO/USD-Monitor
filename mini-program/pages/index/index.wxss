.page { min-height: 100vh; padding-bottom: 40rpx; }
.mx-24 { margin-left: 24rpx; margin-right: 24rpx; }
.mt-4 { margin-top: 4rpx; }
.mb-16 { margin-bottom: 16rpx; }

/* Decision bar */
.decision-bar {
  display: flex; flex-direction: row; align-items: center;
  background: rgba(15, 23, 42, 0.6); border: 1rpx solid rgba(51, 65, 85, 0.5);
  border-radius: 20rpx; padding: 20rpx 0; margin-top: 16rpx; margin-bottom: 20rpx;
}
.decision-cell { flex: 1; display: flex; flex-direction: column; align-items: center; gap: 6rpx; }
.decision-label { font-size: 22rpx; color: #64748b; }
.decision-value { font-size: 30rpx; font-weight: 700; color: #e2e8f0; }
.decision-divider { width: 1rpx; height: 48rpx; background: rgba(51, 65, 85, 0.5); }

/* Grid */
.grid-2col { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; margin-top: 16rpx; }
.g-card {
  display: flex; flex-direction: column;
  background: rgba(15, 23, 42, 0.6); border: 1rpx solid rgba(51, 65, 85, 0.5);
  border-radius: 20rpx; padding: 20rpx 24rpx;
}
.g-label { font-size: 22rpx; color: #64748b; margin-bottom: 8rpx; }
.g-value { font-size: 36rpx; font-weight: 700; color: #e2e8f0; }

/* Catalysts */
.catalyst-row {
  display: flex; flex-direction: row; padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(51, 65, 85, 0.2);
}
.catalyst-row:last-child { border-bottom: none; }
.catalyst-time { width: 100rpx; flex-shrink: 0; padding-top: 4rpx; }
.catalyst-body { flex: 1; }

/* Asset columns */
.asset-cols { display: flex; flex-direction: row; gap: 16rpx; }
.asset-col {
  flex: 1; background: rgba(15, 23, 42, 0.6); border: 1rpx solid rgba(51, 65, 85, 0.5);
  border-radius: 20rpx; padding: 20rpx;
}
.asset-item { margin-bottom: 16rpx; }
.asset-item:last-child { margin-bottom: 0; }
.ticker-badge {
  font-size: 20rpx; font-weight: 600; color: #38bdf8;
  background: rgba(56, 189, 248, 0.1); padding: 2rpx 10rpx; border-radius: 8rpx;
}

/* NAV chart */
.nav-chart { width: 100%; height: 300rpx; }
